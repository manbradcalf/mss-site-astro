---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import Packages from "../components/Packages.astro";
import BlogSection from "../components/BlogSection.astro";
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
import Partners from "../components/Partners.astro";
import Testimonials from "../components/Testimonials.astro";
import { services } from "../components/Services.astro";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Medcalf Software Solutions",
  url: "https://medcalfsoftwaresolutions.com",
  logo: "https://medcalfsoftwaresolutions.com/images/M Logo.svg",
  description:
    "Gundalo (by Medcalf Software Solutions) builds the semantic layer and graph backbone that make AI answer correctly on your real data — plain-English data queries you can trust, knowledge graphs, GraphRAG, and AI document processing.",
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+1-804-259-2533",
    contactType: "sales",
    email: "hello@medcalfsoftwaresolutions.com",
  },
  sameAs: ["https://www.linkedin.com/company/medcalf-software-solutions-llc"],
};

const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Graph Database and AI Solutions",
  provider: {
    "@type": "Organization",
    name: "Medcalf Software Solutions",
  },
  areaServed: "Worldwide",
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Software Services",
    itemListElement: services.map((service) => ({
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: service.title,
        description: service.description,
      },
    })),
  },
};
---

<Layout
  title="Gundalo — Ask Your Data Hard Questions. Trust the Answer."
  description="Gundalo (by Medcalf Software Solutions) makes the answers right on your real, messy data — so you can ask your business hard questions in plain English and trust what comes back."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(organizationSchema)}
  />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(servicesSchema)}
  />
  <Navigation />
  <Hero />
  <Services />
  <Packages />
  <Testimonials />
  <BlogSection />
  <ContactForm />
  <Footer />
</Layout>
