---
// src/components/Hero.astro
---

<section id="home" class="hero">
  <div class="hero-container">
    <div class="hero-content">
      <h1 class="hero-title">Ask your data the hard questions. Trust the answer.</h1>
      <p class="hero-subtitle">
        "Talk to your data" tools demo perfectly — then quietly answer wrong on
        your real, messy data. Gundalo makes the answers right, so you can
        finally ask the questions you've been told are too complicated to pull.
      </p>
      <div class="hero-buttons">
        <a href="#packages" class="btn btn-primary">Get an accuracy audit</a>
        <a href="#services" class="btn btn-secondary">See what we do</a>
      </div>
    </div>
    <div class="hero-image">
      <div class="hero-graphic">
        <img
          src="/images/gundalo_icon_cream.svg"
          alt="Gundalo Logo"
          class="hero-logo"
        />
      </div>
    </div>
  </div>
</section>
