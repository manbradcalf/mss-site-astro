---
// src/components/Packages.astro
const packages = [
  {
    name: "Discovery Sprint",
    price: "$3,500",
    term: "fixed · 1 week",
    bestFor: "Validating an idea before committing budget",
    features: [
      "Technical feasibility assessment",
      "Architecture recommendation",
      "Scope & estimate for build phase",
      "Written deliverable you own",
    ],
    featured: true,
  },
  {
    name: "Build Sprint",
    price: "$6,000–$15,000",
    term: "fixed · 2–6 weeks",
    bestFor: "Shipping a scoped feature or integration",
    features: [
      "Optional Discovery Sprint",
      "End-to-end implementation",
      "Testing & validation suite",
      "Deployment & monitoring",
      "Training & documentation",
    ],
    featured: false,
  },
  {
    name: "Retainer",
    price: "$2,000+",
    term: "/month · ongoing",
    bestFor: "Teams who want to keep building with MSS",
    features: [
      "Support for what we shipped",
      "Code reviews from who wrote it",
      "Priority when you're ready for the next sprint",
      "Same-day async responses",
    ],
    featured: false,
  },
];

const steps = [
  { number: "1", title: "We talk", description: "No commitment, no pitch" },
  {
    number: "2",
    title: "I scope it",
    description: "Clear deliverables & price",
  },
  { number: "3", title: "I build it", description: "You stay in the loop" },
  {
    number: "4",
    title: "You decide",
    description: "Continue, pause, or wrap up",
  },
];
---

<section id="packages" class="packages">
  <div class="container">
    <div class="section-header">
      <h2>How We Work Together</h2>
      <p>Scoped engagements with clear deliverables</p>
    </div>
    <div class="packages-grid">
      {
        packages.map((pkg) => (
          <div class={`package-card${pkg.featured ? " featured" : ""}`}>
            {pkg.featured && <span class="package-badge">Most Popular</span>}
            <div class="package-header">
              <h3>{pkg.name}</h3>
            </div>
            <div class="package-price">
              <span class="amount">{pkg.price}</span>
              <span class="period">{pkg.term}</span>
            </div>
            <ul class="package-features">
              {pkg.features.map((feature) => (
                <li>
                  <i class="fas fa-check" /> {feature}
                </li>
              ))}
            </ul>
            <p class="package-best-for">
              <strong>Best for:</strong> {pkg.bestFor}
            </p>
            <a
              href="#contact"
              class={`btn ${pkg.featured ? "btn-primary" : "btn-secondary"}`}
            >
              Get Started
            </a>
          </div>
        ))
      }
    </div>

    <div class="how-it-works">
      <h3>How It Works</h3>
      <div class="steps-flow">
        {
          steps.map((step, i) => (
            <>
              <div class="step">
                <span class="step-number">{step.number}</span>
                <strong>{step.title}</strong>
                <span class="step-desc">{step.description}</span>
              </div>
              {i < steps.length - 1 && <span class="step-arrow">→</span>}
            </>
          ))
        }
      </div>
      <a href="#contact" class="btn btn-primary" style="margin-top: 2rem;"
        >Let's Talk</a
      >
    </div>
  </div>
</section>
