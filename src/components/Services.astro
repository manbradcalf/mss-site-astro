---
// src/components/Services.astro
export const services = [
  {
    icon: "fas fa-comments",
    title: "Ask anything, in plain English",
    description: "The questions you actually care about — typed the way you'd say them out loud. No query language, no dashboard backlog, no waiting on the data team to get back to you.",
    link: null
  },
  {
    icon: "fas fa-circle-check",
    title: "Answers you can act on",
    description: "The most dangerous report is the one that looks right and isn't. We pressure-test every answer against the questions you sign off on — so the number you make a decision on is the right number.",
    link: null
  },
  {
    icon: "fas fa-diagram-project",
    title: "Connect the dots across your whole business",
    description: "\"Who's tied to this flagged account?\" \"If this supplier goes down, what gets hit?\" \"Show me everything touching this customer.\" The questions that span everything — answered in one shot, not five spreadsheets.",
    link: "/services/graph-database-services"
  },
  {
    icon: "fas fa-file-lines",
    title: "Unlock what's buried in your documents",
    description: "Contracts, PDFs, reports, policies — the answers locked inside them, pulled out and made as easy to ask about as anything else you own.",
    link: "/services/document-processing-pipeline"
  },
  {
    icon: "fas fa-robot",
    title: "Hand off the busywork",
    description: "AI workers that run the repetitive jobs for you — outreach, data entry, reporting, inbox triage — so your team spends its hours on the work that actually needs a human.",
    link: "/services/custom-ai-agents"
  },
  {
    icon: "fas fa-shield-halved",
    title: "Built to be trusted, not just demoed",
    description: "A decade spent breaking software is what qualifies us to build the kind that holds up. We'll also tell you straight when you don't need us — honesty is the whole point.",
    link: null
  }
];
---

<section id="services" class="services">
  <div class="container">
    <div class="section-header">
      <h2>What You Get</h2>
      <p>Straight answers to the questions you've been told are "too complicated to pull."</p><br/><p>Ask in plain English. Trust what comes back.</p>
    </div>
    <div class="services-grid">
      {
        services.map((service) => (
          service.link ? (
            <a href={service.link} class="service-card service-card-link">
              <div class="service-icon">
                <i class={service.icon} />
              </div>
              <h3>{service.title}</h3>
              <p>{service.description}</p>
              <span class="learn-more">Learn more →</span>
            </a>
          ) : (
            <div class="service-card">
              <div class="service-icon">
                <i class={service.icon} />
              </div>
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </div>
          )
        ))
      }
    </div>
  </div>
</section>
