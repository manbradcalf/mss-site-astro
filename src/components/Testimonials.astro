<section id="testimonials" class="testimonials">
  <div class="container">
    <div class="section-header">
      <h2>Testimonials</h2>
    </div>
    <div class="testimonials-carousel">
      <button class="carousel-arrow carousel-arrow-left" aria-label="Previous testimonials">&#8249;</button>
      <div class="testimonials-viewport">
        <div class="testimonials-track">
          <div class="testimonial-slide">
            <div class="testimonial-card">
              <div class="testimonial-content">
                <p><em>"Ben integrated the ChatGPT API into our platform to extract data from unstructured settlement statement PDFs. I was impressed with Ben's ability to build a PoC quickly, iterate on feedback, and then integrate a usable solution into our production software stack."</em></p>
              </div>
              <div class="testimonial-author">
                <div class="author-info">
                  <h4><a href="https://www.linkedin.com/in/joe-acanfora-5a4a3164/" target="_blank" rel="noopener noreferrer">Joe Acanfora</a></h4>
                  <span>Technical Co-Founder</span>
                </div>
              </div>
            </div>
          </div>
          <div class="testimonial-slide">
            <div class="testimonial-card">
              <div class="testimonial-content">
                <p><em>"If I had to choose one word to describe Ben, it would be innovate. Not the buzzword version that gets tossed around in startup marketing decks, but innovation in its truest sense: deep, practical, and lived every day."</em></p>
              </div>
              <div class="testimonial-author">
                <div class="author-info">
                  <h4><a href="https://www.linkedin.com/in/jamiepinkham/" target="_blank" rel="noopener noreferrer">Jamie Pinkham</a></h4>
                  <span>Senior Lead Software Engineer</span>
                </div>
              </div>
            </div>
          </div>
          <div class="testimonial-slide">
            <div class="testimonial-card">
              <div class="testimonial-content">
                <p><em>"Ben was an excellent engineer for us and was always actively learning and improving his craft...If I had an opportunity to work again with Ben the answer would be an unequivocal 'yes'!"</em></p>
              </div>
              <div class="testimonial-author">
                <div class="author-info">
                  <h4><a href="https://www.linkedin.com/in/keith-kienzle-6291556/" target="_blank" rel="noopener noreferrer">Keith Kienzle</a></h4>
                  <span>Senior Android Engineer</span>
                </div>
              </div>
            </div>
          </div>
          <div class="testimonial-slide">
            <div class="testimonial-card">
              <div class="testimonial-content">
                <p><em>"Ben was collaborative, proactive and genuinely cared about doing things the right way."</em></p>
              </div>
              <div class="testimonial-author">
                <div class="author-info">
                  <h4><a href="https://www.linkedin.com/in/brandi-levine-19b671103/" target="_blank" rel="noopener noreferrer">Brandi Levine</a></h4>
                  <span>Software Test Analyst</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <button class="carousel-arrow carousel-arrow-right" aria-label="Next testimonials">&#8250;</button>
    </div>
  </div>
</section>

<script>
  const track = document.querySelector<HTMLElement>('.testimonials-track');
  const slides = document.querySelectorAll('.testimonial-slide');
  const leftArrow = document.querySelector('.carousel-arrow-left');
  const rightArrow = document.querySelector('.carousel-arrow-right');
  let page = 0;

  // One testimonial per page on mobile, two per page on wider screens.
  const slidesPerPage = () =>
    window.matchMedia('(max-width: 768px)').matches ? 1 : 2;

  const pageCount = () => Math.ceil(slides.length / slidesPerPage());

  function render() {
    if (!track) return;
    const pages = pageCount();
    // Keep the page index in range (also handles wrap-around from the arrows).
    page = ((page % pages) + pages) % pages;
    track.style.transform = `translateX(-${page * 100}%)`;
  }

  leftArrow?.addEventListener('click', () => {
    page -= 1;
    render();
  });

  rightArrow?.addEventListener('click', () => {
    page += 1;
    render();
  });

  // Re-clamp the page when crossing the mobile/desktop breakpoint.
  window.addEventListener('resize', render);

  render();
</script>
